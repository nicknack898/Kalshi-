KALSHI_ENV=demo
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
DATABASE_URL=sqlite:///./kalshi_bot.db
ENABLE_LIVE_TRADING=false
PLACE_REAL_ORDERS=false
USE_WEBSOCKETS=true
SCAN_INTERVAL_SECONDS=60
MAX_SINGLE_POSITION_PCT=0.05
MAX_TOTAL_OPEN_EXPOSURE_PCT=0.30
MAX_DAILY_LOSS_PCT=0.15
MAX_DRAWDOWN_PCT=0.08
FRACTIONAL_KELLY=0.25
EDGE_THRESHOLD=0.04
MAX_SLIPPAGE_DOLLARS=0.02
MIN_EXPECTED_PROFIT_DOLLARS=5.00
MAX_AI_COST_PER_DAY_USD=50.00
STOP_FILE_PATH=./STOP
LLM_ENABLED=true
NEWS_PROVIDER_ENABLED=true
X_PROVIDER_ENABLED=false
REDDIT_PROVIDER_ENABLED=false
